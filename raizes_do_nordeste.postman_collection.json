          "name": "T01 - Cadastro válido",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/clientes/cadastro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "cadastro"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Felipe\",\n  \"cpf\": \"03139686080\",\n  \"senha\": \"12345\",\n  \"consentimento\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code é 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response contém cliente.id\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.cliente).to.have.property(\"id\");",
                  "    pm.collectionVariables.set(\"clienteId\", json.cliente.id);",
