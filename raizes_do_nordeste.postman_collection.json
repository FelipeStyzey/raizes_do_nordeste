          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Este teste só passa se o pedido já estiver em EM_PREPARO",
                  "// (ou seja, após rodar Pagamento/01 - Aprovado com sucesso)",
                  "pm.test(\"Status code é 200 ou 409 (depende do status atual do pedido)\", function () {",
                  "    pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    pm.test(\"Pedido avançou para PRONTO\", function () {",
                  "        var json = pm.response.json();",
                  "        pm.expect(json.pedido.status).to.eql(\"PRONTO\");",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
